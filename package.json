{
  "name": "slides",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 execute slides-db --local --file migrations/0001_create_presentations.sql",
    "db:migrate:remote": "wrangler d1 migrations apply slides-db --remote",
    "scan": "bun run scripts/scan-presentations.ts",
    "scan:remote": "bun run scripts/scan-presentations.ts --remote"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250109.0",
    "@types/bcryptjs": "^2.4.6",
    "bun-types": "^1.3.14",
    "typescript": "^5.7.2",
    "wrangler": "^4.110.0"
  }
}
